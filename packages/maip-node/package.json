{
  "name": "@maip/node",
  "version": "0.1.0",
  "description": "Standalone MAIP node — HTTP server implementing the MAIP protocol",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "maip-node": "dist/bin.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "start": "tsx src/bin.ts"
  },
  "dependencies": {
    "@maip/core": "*",
    "express": "^5.1.0",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "license": "MIT"
}
