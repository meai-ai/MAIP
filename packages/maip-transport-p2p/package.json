{
  "name": "@maip/transport-p2p",
  "version": "0.1.0",
  "description": "libp2p-based P2P transport for the MAIP protocol",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@maip/core": "*",
    "@maip/node": "*",
    "libp2p": "^3.1.0",
    "@libp2p/tcp": "^11.0.0",
    "@libp2p/websockets": "^10.1.0",
    "@libp2p/noise": "^1.0.0",
    "@libp2p/yamux": "^8.0.0",
    "@libp2p/kad-dht": "^16.1.0",
    "@libp2p/identify": "^4.0.0",
    "@libp2p/circuit-relay-v2": "^4.1.0",
    "@libp2p/dcutr": "^3.0.0",
    "@libp2p/bootstrap": "^12.0.0",
    "@libp2p/ping": "^3.0.0",
    "@libp2p/crypto": "^5.1.0",
    "@libp2p/peer-id": "^6.0.0",
    "@libp2p/interface": "^3.1.0",
    "multiformats": "^13.4.0",
    "uint8arrays": "^5.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "license": "MIT"
}
